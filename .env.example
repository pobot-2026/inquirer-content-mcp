# Arc XP Content API Configuration
# Copy to .env and fill in your credentials

# Arc XP API Token (required for Arc backend)
PMN_SANDBOX_CONTENT_API=your_token_here

# Arc API Base URL (defaults to sandbox)
ARC_API_BASE_URL=https://api.sandbox.pmn.arcpublishing.com

# Arc Website ID
ARC_WEBSITE=philly-media-network
